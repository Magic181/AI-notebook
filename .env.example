# Django
DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database: USE_SQLITE=true 使用 SQLite；设为 false 并配置 MYSQL_* 使用 MySQL
USE_SQLITE=false
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=ai_notebook
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# AI (optional)
OPENAI_API_KEY=
